        111222333, 444555666, 777888999, 101112131, 141516171, 181920212, 222324252, 262728293, 303132333, 343536373,
        383940414, 454647484, 494847464, 505152535, 565758595, 606162636, 646566676, 707172737, 747576777, 787980818,
        858687888, 909192939, 949596979, 999100101
    )
),FilteredObjects AS (
    SELECT DISTINCT ObjCode
    FROM MaskedTable1
),
RolePriorities AS (
    SELECT 
        mt1.ObjCode,
        mt1.CliCode,
        MaskedBrandTable.CliBrandCode,
        MaskedBrandTable.CliBrandName,
        mt1.RoleCode,
        CASE WHEN mt1.RoleCode IN ('OWNERSHIP','DEVELOPER') THEN MaskedBrandTable.CliBrandName ELSE NULL END AS Developer,
        ObjDescriptionTable.ObjName,
        CASE
            WHEN mt1.RoleCode IN ('ROLE_X') THEN 1
            WHEN mt1.RoleCode = 'ROLE_X' THEN 2
            WHEN mt1.RoleCode = 'ROLE_X' THEN 3
            WHEN mt1.RoleCode = 'ROLE_X' THEN 4
            WHEN mt1.RoleCode = 'ROLE_X' THEN 5
            WHEN mt1.RoleCode = 'ROLE_X' THEN 6
            WHEN mt1.RoleCode = 'ROLE_X' THEN 7
            WHEN mt1.RoleCode = 'ROLE_X' THEN 8
            ELSE 9
        END AS Priority,
        ROW_NUMBER() OVER (
            PARTITION BY mt1.CliCode, mt1.ObjCode
            ORDER BY 
                CASE
                     WHEN mt1.RoleCode IN ('ROLE_X','ROLE_X') THEN 1
                     WHEN mt1.RoleCode = 'ROLE_X' THEN 2
                     WHEN mt1.RoleCode = 'ROLE_X' THEN 3
                     WHEN mt1.RoleCode = 'ROLE_X' THEN 4
                     WHEN mt1.RoleCode = 'ROLE_X' THEN 5
                     WHEN mt1.RoleCode = 'ROLE_X' THEN 6
                     WHEN mt1.RoleCode = 'ROLE_X' THEN 7
                     WHEN mt1.RoleCode ='ROLE_X' THEN 8
                    ELSE 9
                END
        ) AS rn
    FROM MaskedSchema.RoleTable mt1
    LEFT JOIN MaskedBrandTable ON MaskedBrandTable.CliCode = mt1.CliCode
    LEFT JOIN MaskedObjDescTable ON mt1.ObjCode = MaskedObjDescTable.ObjCode
    WHERE mt1.ObjCode IN (SELECT ObjCode FROM FilteredObjects)
),
RoleRespBrand AS (
    SELECT DISTINCT
        MaskedBrandTable.CliBrandCode,
        CASE 
            WHEN MaskedBrandTable.CliBrandCode IN (111111,222222,333333) THEN 'Masked Name 1'
            WHEN MaskedBrandTable.CliBrandCode IN (444444,555555) THEN 'Masked Name 2'
            ELSE 'Unknown' 
        END AS ResponsiblePerson
    FROM MaskedSchema.RoleTable mt1
    LEFT JOIN MaskedBrandTable ON MaskedBrandTable.CliCode = mt1.CliCode
    WHERE
        mt1.RoleCode IN ('GENERAL_CONTRACTOR', 'OWNERSHIP')
    AND MaskedBrandTable.CliBrandCode IN (111111,222222,333333,444444,555555)
),
SalesSumClientQ1 AS (
    SELECT
        xxx.CliCode,
        ROUND(SUM(xxx.SumSaled), 2) AS Sales_Q1_202X
    FROM MaskedSchema.ClientTurnover ctdf
    WHERE xxx.DataInfo >= 'XXXX-XX-XX' AND xxx.DataInfo <= 'XXXX-XX-XX'
    GROUP BY xxx.CliCode
),
SalesSumClientObjectQ1 AS (
    SELECT
        xxx.CliCode,
        xxx.ObjCode,
