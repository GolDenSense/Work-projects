WITH MaskedObjectCodes AS (
    SELECT 
        t1.ObjCode
    FROM DataTable1.RoleObjectMapping t1
    LEFT JOIN DescriptionTable d ON d.Code = t1.ClientCode
    WHERE
        t1.Role IN ('ROLE_A', 'ROLE_B')
    AND d.BrandCode IN ( 
        123456789, 987654321, 112233445, 556677889, 998877665, 443322110, 667788990, 102938475, 564738291, 019283746,
        111222333, 444555666, 777888999, 101112131, 141516171, 181920212, 222324252, 262728293, 303132333, 343536373,
        383940414, 454647484, 494847464, 505152535, 565758595, 606162636, 646566676, 707172737, 747576777, 787980818,
        858687888, 909192939, 949596979, 999100101, 102103104, 105106107, 108109110, 111112113, 114115116, 117118119,
        120121122, 123124125, 126127128, 129130131, 132133134, 135136137, 138139140, 141142143, 144145146, 147148149,
        150151152, 153154155, 156157158, 159160161, 162163164, 165166167, 168169170, 171172173, 174175176, 177178179
    )
),
DistinctObjects AS (
    SELECT DISTINCT ObjCode
    FROM MaskedObjectCodes
),
RolePriority AS (
    SELECT 
        t1.ObjCode,
        t1.ClientCode,
        d.BrandCode,
        d.BrandName,
        t1.Role,
        CASE WHEN t1.Role IN ('ROLE_B', 'ROLE_C') THEN d.BrandName ELSE NULL END AS ResponsiblePerson,
        o.ObjName,
        CASE
            WHEN t1.Role IN ('ROLE_B', 'ROLE_C') THEN 1
            WHEN t1.Role = 'ROLE_A' THEN 2
            WHEN t1.Role = 'ROLE_D' THEN 3
            WHEN t1.Role = 'ROLE_E' THEN 4
            WHEN t1.Role = 'ROLE_F' THEN 5
            WHEN t1.Role = 'ROLE_G' THEN 6
            WHEN t1.Role = 'ROLE_H' THEN 7
            WHEN t1.Role = 'ROLE_I' THEN 8
            ELSE 9
        END AS Priority,
        ROW_NUMBER() OVER (
            PARTITION BY t1.ClientCode, t1.ObjCode
            ORDER BY 
                CASE
                     WHEN t1.Role IN ('ROLE_B', 'ROLE_C') THEN 1
                     WHEN t1.Role = 'ROLE_A' THEN 2
                     WHEN t1.Role = 'ROLE_D' THEN 3
                     WHEN t1.Role = 'ROLE_E' THEN 4
                     WHEN t1.Role = 'ROLE_F' THEN 5
                     WHEN t1.Role = 'ROLE_G' THEN 6
                     WHEN t1.Role = 'ROLE_H' THEN 7
                     WHEN t1.Role = 'ROLE_I' THEN 8
                    ELSE 9
                END
        ) AS rn
    FROM DataTable1.RoleObjectMapping t1
    LEFT JOIN DescriptionTable d ON d.Code = t1.ClientCode
    LEFT JOIN DataTable2.ObjectDesc o ON t1.ObjCode = o.ObjCode
    WHERE t1.ObjCode IN (SELECT ObjCode FROM DistinctObjects)
),
ResponsiblePersons AS (
